        "fromUri": "sip:alice2@test",
        "toUri": "sip:+1234@test",
        "requestUri": "sip:+1234@127.0.0.1:15060"
      }
    },
    {
      "name": "alice3",
      "content": {
        "fromUri": "sip:alice3@test",
        "toUri": "sip:+1234@test",
        "requestUri": "sip:+1234@127.0.0.1:15060"
      }
    }
  ],
  "legs": [
    { "name": "bob1", "checks": { "inviteRuri": { "regex": "^sip:" } } },
