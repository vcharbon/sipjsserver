{
  "name": "sipjsserver",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "CHOKIDAR_USEPOLLING=true tsx --env-file=.env --watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rule-kill": "tsx scripts/rule-kill.ts",
    "dev:profile": "NODE_OPTIONS='--max-old-space-size=600 --expose-gc' B2BUA_EXPOSE_GC=1 CHOKIDAR_USEPOLLING=true tsx --env-file=.env --watch src/main.ts",
    "start:profile": "NODE_OPTIONS='--max-old-space-size=600 --expose-gc' B2BUA_EXPOSE_GC=1 node --env-file=.env dist/main.js",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@effect/opentelemetry": "^4.0.0-beta.42",
    "@effect/platform-node": "^4.0.0-beta.42",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "effect": "^4.0.0-beta.42",
    "ioredis": "^5.10.1",
    "jssip": "^3.13.6"
  },
  "devDependencies": {
    "@effect/language-service": "latest",
    "@effect/vitest": "^4.0.0-beta.43",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.0.0",
    "sip-parser": "^1.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
