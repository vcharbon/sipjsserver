{
  "$schema": "https://raw.githubusercontent.com/Effect-TS/language-service/refs/heads/main/schema.json",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "incremental": false,
    "composite": false,
    "tsBuildInfoFile": null,
    "declaration": false,
    "declarationMap": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "plugins": [],
    "paths": {
      "@vcharbon/sipjs/test-harness": ["./src/test-harness/index.ts"],
      "@vcharbon/sipjs/b2bua": ["./src/b2bua/index.ts"],
      "@vcharbon/sipjs/rules-sdk": ["./src/rules-sdk/index.ts"],
      "@vcharbon/sipjs/sip-front-proxy": ["./src/sip-front-proxy/index.ts"],
      "@vcharbon/sipjs/sip": ["./src/sip/index.ts"],
      "@vcharbon/sipjs/observability": ["./src/observability/index.ts"]
    }
  },
  "include": [
    "tests/support/**/*",
    "tests/fullcall/framework/**/*",
    "tests/harness/**/*",
    "src/**/*"
  ],
  "exclude": ["**/*.test.ts", "**/*.test-d.ts"]
}
