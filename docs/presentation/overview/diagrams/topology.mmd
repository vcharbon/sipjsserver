flowchart TB
    Alice([Alice])
    Bob([Bob / SBC])
    Backend[("CallControl backend")]
    SharedRedis[("Shared Redis (CallLimiter)")]

    subgraph T1["TIER 1 — SIP Front Proxy (stateless)"]
        direction LR
        ProxyA["proxy-A · ACTIVE / VIP"]
        ProxyB["proxy-B · BACKUP"]
        ProxyA <-. "VRRP keepalived (~2s)" .-> ProxyB
    end

    subgraph T2["TIER 2 — B2BUA Workers (stateful)"]
        direction LR
        W0["worker-0 + sidecar redis"]
        W1["worker-1 + sidecar redis"]
        W2["worker-2 + sidecar redis"]
        W0 <-. "/replog" .-> W1
        W1 <-. "/replog" .-> W2
    end

    Alice -->|UDP :5060| T1
    T1 -->|UDP :5060| Bob
    T1 -->|"HRW(Call-ID) + HMAC Record-Route"| T2
    T2 --> Backend
    T2 --> SharedRedis

