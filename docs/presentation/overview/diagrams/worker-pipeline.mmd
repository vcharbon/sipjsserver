    style AE fill:#1E293B,stroke:#F472B6,color:#F1F5F9,stroke-width:2px
    style IE fill:#1E293B,stroke:#34D399,color:#F1F5F9,stroke-width:2px
    style SR fill:#1E293B,stroke:#22D3EE,color:#F1F5F9,stroke-width:2px
