flowchart LR
    UDP[UDP packet]
    TL[TransactionLayer]
    RE[RuleExecutor]
    AE[ActionExecutor]
    IE[InvariantEnforcer]
    SR[SipRouter]
    UDP --> TL --> RE --> AE --> IE --> SR

    TL_DESC["parse, dedupe,<br/>CSeq/branch tracking"]
    RE_DESC["match by<br/>specificity score"]
    AE_DESC["translate typed actions<br/>into SIP message ops"]
    IE_DESC["check SIP rules<br/>(RFC 3261)"]
    SR_DESC["outbound UDP send"]

    TL -.- TL_DESC
    RE -.- RE_DESC
    AE -.- AE_DESC
    IE -.- IE_DESC
    SR -.- SR_DESC

    style UDP fill:#0B1120,stroke:#94A3B8,color:#F1F5F9
